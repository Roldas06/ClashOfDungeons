[sub_resource type="GDScript" id="GDScript_4flbx"]
script/source = "extends CharacterBody2D
@export var speed = 10.0
@export var jump_power = 10.0
@export var gravity = 900.0
var is_in_lava = false
var speed_multiplier = 30.0
var jump_multiplier = -30.0
var direction = 0
var jump_count = 0
var maxHealthPoints = 40
var currentHealthPoints: int = maxHealthPoints
signal healthChanged

# --- LAVA DAMAGE VARIABLES ---
var lava_damage_interval = 0.5
var lava_damage_timer = 0.0
var lava_damage_amount = 4

# --- LAVA SWIMMING VARIABLES ---
var lava_swim_power = -160.0
var lava_horizontal_drag = 0.85

func _physics_process(delta: float) -> void:
	# 1. APPLY GRAVITY / LAVA PHYSICS
	if not is_on_floor():
		if is_in_lava:
			# Weak lava gravity — sinks slowly but steadily
			velocity.y += 80.0 * delta * 10
			velocity.y = clamp(velocity.y, -400.0, 80.0)

			_handle_lava_damage(delta)
		else:
			velocity.y += gravity * delta
			lava_damage_timer = 0.0
	else:
		jump_count = 0
		if is_in_lava:
			_handle_lava_damage(delta)
		else:
			lava_damage_timer = 0.0

	# 2. HANDLE JUMP / SWIM
	if Input.is_action_just_pressed(\"ui_accept\"):
		if is_in_lava:
			# Swim stroke upward — no jump count limit in lava
			velocity.y = lava_swim_power
		elif jump_count < 2:
			jump_count += 1
			velocity.y = jump_power * jump_multiplier

	# 3. HANDLE MOVEMENT
	direction = Input.get_axis(\"move_left\", \"move_right\")
	var final_speed = speed * speed_multiplier

	if is_in_lava:
		final_speed = speed * 5.0
		if direction:
			velocity.x = direction * final_speed
		else:
			# Viscous drag in lava
			velocity.x *= lava_horizontal_drag
	else:
		if direction:
			velocity.x = direction * final_speed
		else:
			velocity.x = move_toward(velocity.x, 0, final_speed)

	move_and_slide()

# --- LAVA DAMAGE ---
func _handle_lava_damage(delta: float) -> void:
	lava_damage_timer += delta
	if lava_damage_timer >= lava_damage_interval:
		TakeDamage(lava_damage_amount)
		lava_damage_timer = 0.0

# --- HELPER FUNCTIONS ---
func TakeDamage(damageTaken):
	currentHealthPoints -= damageTaken
	healthChanged.emit(currentHealthPoints)
	modulate = Color(10, 10, 10)
	var tween = create_tween()
	tween.tween_property(self, \"modulate\", Color(1, 1, 1), 0.1)
	if currentHealthPoints <= 0:
		Death()

func ApplyKnockback(force: Vector2) -> void:
	velocity += force

func Death():
	print(\"GAME OVER!\")
	get_tree().change_scene_to_file(\"res://main_menu.tscn\")
"

